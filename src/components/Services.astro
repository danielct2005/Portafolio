---
const services = [
  {
    title: "Agendamiento Online",
    description: "Tus clientes reservan hora a cualquier hora, desde cualquier lugar. Vos evitás perdida de tiempo por llamadas y clientes que no llegan.",
    icon: "calendar"
  },
  {
    title: "Catálogo Digital",
    description: "Tus productos visibles 24/7 sin papel ni intermediarios. Tus clientes compran cuando quieren, desde su celular.",
    icon: "catalog"
  },
  {
    title: "Invitaciones Digitales",
    description: "Invitaciones interactivas y elegantes para bodas, eventos y celebraciones. Tus invitados confirman online sin papel.",
    icon: "invitation"
  },
  {
    title: "Web Corporativa",
    description: "Una presencia profesional que genera confianza al primer clic. Tu negocio se ve serio desde el primer momento.",
    icon: "web"
  }
];
---

<section class="py-20 bg-slate-800/30">
  <div class="container mx-auto px-6">
    <!-- Título de sección -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-100 mb-4">
        Servicios
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto">
        Soluciones digitales que generan resultados reales para tu negocio.
      </p>
    </div>

    <!-- Grid de servicios -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-4 gap-8">
      {services.map((service) => (
        <a 
          href="/Portafolio/contacto" 
          class="block bg-slate-800/50 border border-slate-700/50 rounded-2xl p-8 hover:-translate-y-1 hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-300 group"
        >
          <!-- Icono -->
          <div class="w-12 h-12 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
            {service.icon === "calendar" && (
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            )}
            {service.icon === "catalog" && (
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
              </svg>
            )}
            {service.icon === "invitation" && (
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            )}
            {service.icon === "web" && (
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            )}
          </div>
          
          <!-- Título -->
          <h3 class="text-xl font-bold text-slate-100 mb-3 group-hover:text-emerald-400 transition-colors">
            {service.title}
          </h3>
          
          <!-- Descripción -->
          <p class="text-slate-400 leading-relaxed">
            {service.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>