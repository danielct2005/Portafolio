---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  author?: string;
  articlePublishedTime?: string;
  articleAuthor?: string[];
}

const {
  title,
  description,
  image = "/og-default.svg",
  type = "website",
  author = "Daniel Ceballos",
  articlePublishedTime,
  articleAuthor
} = Astro.props;

// URL base para producción
const siteUrl = "https://danielct2005.github.io/Portafolio";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullImageUrl = `${siteUrl}${image}`;
---

<!-- Meta tags básicos -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="keywords" content="desarrollador web, programador, Chile, Santiago, sistemas agendamiento, catálogos digitales, frontend, backend, full stack" />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:site_name" content="DC Dev" />
<meta property="og:locale" content="es_CL" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

{articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
{articleAuthor && articleAuthor.map((a) => <meta property="article:author" content={a} />)}

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@danielct2005" />
<meta name="twitter:creator" content="@danielct2005" />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />

<!-- LinkedIn / Microsoft -->
<meta name="linkedin:owner" content="danielct2005" />

<!-- Robots -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
<meta name="bingbot" content="index, follow" />

<!-- Verificación Google Search Console -->
<meta name="google-site-verification" content="google-site-verification-code" />

<!-- Tema de color -->
<meta name="theme-color" content="#0f172a" />

<!-- Schema.org JSON-LD para Person -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Daniel Ceballos",
  "url": "https://danielct2005.github.io/Portafolio",
  "jobTitle": "Desarrollador Full Stack",
  "description": "Desarrollador de sistemas de agendamiento y catálogos web para negocios en Chile",
  "email": "daniel.dcdev04@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Santiago",
    "addressRegion": "CL",
    "addressCountry": "CL"
  },
  "sameAs": [
    "https://www.linkedin.com/in/daniel-ceballos-a08390304"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "DC Dev"
  }
}
</script>

<!-- Schema.org para Website -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "DC Dev - Portafolio",
  "url": "https://danielct2005.github.io/Portafolio",
  "description": "Sistemas de agendamiento y catálogos web para negocios chilenos",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://danielct2005.github.io/Portafolio/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>