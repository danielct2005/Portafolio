---
// Header de navegación
const navItems = [
  { name: "Inicio", href: "/Portafolio/" },
  { name: "Sobre Mí", href: "/Portafolio/about" },
  { name: "Proyectos", href: "/Portafolio/projects" },
  { name: "Contacto", href: "/Portafolio/contacto" },
];

const currentPath = Astro.url.pathname;
const basePath = "/Portafolio";
---

<header class="fixed top-0 left-0 right-0 z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800/50">
  <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo / Nombre -->
    <a href="/Portafolio/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="/Portafolio/logo.svg" alt="DC Dev" class="h-12 w-auto" />
    </a>

    <!-- Navegación desktop -->
    <ul class="hidden md:flex items-center gap-6">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href}
            class:list={[
              "text-slate-300 hover:text-emerald-400 transition-colors font-medium text-sm",
              currentPath === item.href && "text-emerald-400"
            ]}
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>

    <!-- Botón menú móvil -->
    <button 
      id="mobile-menu-btn"
      class="md:hidden p-2 text-slate-400 hover:text-emerald-400 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
</header>

<!-- Menú móvil overlay -->
<div 
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-slate-900/95 backdrop-blur-md transform translate-x-full transition-transform duration-300 md:hidden"
  aria-hidden="true"
>
  <!-- Botón cerrar -->
  <button 
    id="close-menu-btn"
    class="absolute top-6 right-6 p-2 text-slate-400 hover:text-emerald-400 transition-colors"
    aria-label="Cerrar menú"
  >
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Links del menú -->
  <div class="flex flex-col items-center justify-center h-full gap-8">
    {navItems.map((item) => (
      <a 
        href={item.href}
        class:list={[
          "text-2xl font-medium text-slate-300 hover:text-emerald-400 transition-colors",
          currentPath === item.href && "text-emerald-400"
        ]}
      >
        {item.name}
      </a>
    ))}
  </div>
</div>

<!-- Espaciador para navbar fijo -->
<div class="h-20"></div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileMenuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  mobileMenuBtn?.addEventListener('click', openMenu);
  closeMenuBtn?.addEventListener('click', closeMenu);

  // Cerrar menú al hacer click en un enlace
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Cerrar menú con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.getAttribute('aria-hidden') === 'false') {
      closeMenu();
    }
  });
</script>