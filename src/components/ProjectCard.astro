---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
}

const { project, index = 0 } = Astro.props;
const { data } = project;
const { title, description, technologies, image, liveUrl } = data;

// Generar el slug del proyecto
const projectSlug = project.id.replace(/\.md$/, '');
---

<a 
  href={`/Portafolio/projects/${projectSlug}`}
  class="group block relative bg-slate-800/50 border border-slate-700/50 rounded-2xl overflow-hidden hover:-translate-y-1 hover:border-emerald-500/40 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-300"
  style={`animation-delay: ${index * 100}ms`}
>
  <!-- Imagen del proyecto -->
  <div class="relative h-48 overflow-hidden">
    <img 
      src={image} 
      alt={`Captura de pantalla del proyecto ${title}`}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent"></div>
    
    <div class="absolute bottom-4 left-4 right-4">
      <div class="flex flex-wrap gap-2">
        {technologies.slice(0, 3).map((tech) => (
          <span class="px-2 py-1 text-xs font-medium bg-slate-900/80 text-emerald-400 rounded-md border border-slate-700/50">
            {tech}
          </span>
        ))}
        {technologies.length > 3 && (
          <span class="px-2 py-1 text-xs font-medium bg-slate-900/80 text-slate-400 rounded-md border border-slate-700/50">
            +{technologies.length - 3}
          </span>
        )}
      </div>
    </div>
  </div>

  <!-- Contenido -->
  <div class="p-6">
    <h3 class="text-xl font-bold text-slate-100 mb-2 group-hover:text-emerald-400 transition-colors">
      {title}
    </h3>

    <p class="text-slate-400 text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5">
      {technologies.map((tech) => (
        <span class="text-xs text-slate-500 bg-slate-800/80 px-2 py-1 rounded">
          {tech}
        </span>
      ))}
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>