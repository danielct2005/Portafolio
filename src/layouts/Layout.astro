---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { 
  title, 
  description = "Portafolio de Analista Programador - Desarrollador Frontend", 
  image = "/Portafolio/og-default.svg",
  type = "website"
} = Astro.props;

const siteTitle = `${title} | Analista Programador`;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" type="image/svg+xml" href="/Portafolio/favicon.svg" />
    <SEOHead 
      title={siteTitle} 
      description={description}
      image={image}
      type={type}
    />
    <meta name="view-transition" content="same-origin" />
    <script defer data-domain="danielct2005.github.io/Portafolio" src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      (function() {
        console.log('[Cache] Iniciando verificación de cache...');
        
        const versionKey = 'portfolio_version';
        const currentVersion = '20250407'; // Nueva versión - cambia cada vez que haces deploy
        
        const storedVersion = localStorage.getItem(versionKey);
        console.log('[Cache] Versión guardada:', storedVersion);
        console.log('[Cache] Versión actual:', currentVersion);
        
        if (storedVersion !== currentVersion) {
          console.log('[Cache] ¡Versión diferente! Limpiando cache y recargando...');
          localStorage.setItem(versionKey, currentVersion);
          
          if ('caches' in window) {
            console.log('[Cache] Limpiando caches del navegador...');
            caches.keys().then(names => {
              console.log('[Cache] Caches encontrados:', names);
              names.forEach(name => {
                caches.delete(name).then(() => console.log('[Cache] Eliminado:', name));
              });
            });
          } else {
            console.log('[Cache] API caches no disponible');
          }
          
          // Forzar recarga sin cache
          console.log('[Cache] Recargando página...');
          window.location.reload();
        } else {
          console.log('[Cache] Versión sama - nada que hacer');
        }
      })();
    </script>
  </head>
  
  <body class="bg-slate-900 text-slate-100 antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>