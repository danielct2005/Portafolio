---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { 
  title, 
  description = "Portafolio de Analista Programador - Desarrollador Frontend", 
  image = "/Portafolio/og-default.svg",
  type = "website"
} = Astro.props;

const siteTitle = `${title} | Analista Programador`;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" type="image/svg+xml" href="/Portafolio/favicon.svg" />
    <SEOHead 
      title={siteTitle} 
      description={description}
      image={image}
      type={type}
    />
    <meta name="view-transition" content="same-origin" />
    <script defer data-domain="danielct2005.github.io/Portafolio" src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      // Verificar si la página fue cargada desde cache
      const navType = performance.getEntriesByType("navigation")[0]?.type;
      console.log('[Cache] Tipo de navegación:', navType);
      
      // Si viene de cache (back/forward o normal), forzar reload
      if (navType === 'back_forward' || navType === 'navigate') {
        // Verificar si ya recargamos en esta sesión
        if (!sessionStorage.getItem('reloaded_once')) {
          console.log('[Cache] Primera carga - forzar reload sin cache');
          sessionStorage.setItem('reloaded_once', 'true');
          
          if ('caches' in window) {
            caches.keys().then(names => {
              names.forEach(name => caches.delete(name));
            });
          }
          
          window.location.reload();
        } else {
          console.log('[Cache] Ya recargamos antes - OK');
        }
      } else {
        console.log('[Cache] Tipo de nav:', navType);
      }
    </script>
  </head>
  
  <body class="bg-slate-900 text-slate-100 antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>