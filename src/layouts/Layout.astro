---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { 
  title, 
  description = "Portafolio de Analista Programador - Desarrollador Frontend", 
  image = "/Portafolio/og-default.svg",
  type = "website"
} = Astro.props;

const siteTitle = `${title} | Analista Programador`;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <link rel="icon" type="image/svg+xml" href="/Portafolio/favicon.svg" />
    <SEOHead 
      title={siteTitle} 
      description={description}
      image={image}
      type={type}
    />
    <meta name="view-transition" content="same-origin" />
    <script defer data-domain="danielct2005.github.io/Portafolio" src="https://plausible.io/js/script.js"></script>
    <script is:inline>
      // Usar pageshow para detectar cuando la página viene del cache del navegador
      window.addEventListener('pageshow', function(event) {
        console.log('[Cache] pageshow - persisted:', event.persisted);
        
        // Si la página vino del bfcache (back-forward cache) o si es la primera vez
        if (event.persisted || !sessionStorage.getItem('first_load_done')) {
          console.log('[Cache] Página desde cache o primera vez - recargando...');
          sessionStorage.setItem('first_load_done', 'true');
          
          if ('caches' in window) {
            caches.keys().then(names => {
              names.forEach(name => caches.delete(name));
            });
          }
          
          window.location.reload();
        } else {
          console.log('[Cache] Carga normal - OK');
        }
      });
      
      // También ejecutar al inicio por si pageshow no se dispara
      if (!sessionStorage.getItem('first_load_done')) {
        console.log('[Cache] Sin marca de primera carga');
      }
    </script>
  </head>
  
  <body class="bg-slate-900 text-slate-100 antialiased min-h-screen flex flex-col">
    <Header />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer />
  </body>
</html>