---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada">
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="container mx-auto px-6 text-center">
      <!-- 404 grande -->
      <h1 class="text-[150px] md:text-[200px] font-bold text-slate-800 leading-none mb-4">
        404
      </h1>
      
      <!-- Mensaje -->
      <h2 class="text-2xl md:text-3xl font-bold text-slate-100 mb-4">
        Página no encontrada
      </h2>
      <p class="text-slate-400 max-w-md mx-auto mb-8">
        La página que buscas no existe o moviste el link. Pero no te preocupes, aquí tienes opciones:
      </p>
      
      <!-- Links útiles -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="/" 
          class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/25"
        >
          Volver al inicio
        </a>
        <a 
          href="/projects" 
          class="px-6 py-3 border border-slate-600 hover:border-emerald-500 text-slate-300 hover:text-emerald-400 font-medium rounded-lg transition-all duration-300"
        >
          Ver mis proyectos
        </a>
      </div>
      
      <!-- Decorative element -->
      <div class="mt-16 text-slate-600">
        <svg class="w-16 h-16 mx-auto opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
    </div>
  </section>
</Layout>