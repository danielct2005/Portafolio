---
import Layout from '../layouts/Layout.astro';

const skills = [
  { category: "Frontend", items: ["React", "Next.js", "Astro", "Tailwind CSS", "TypeScript", "JavaScript"] },
  { category: "Backend", items: ["Node.js", "Java", "Python", "Express", "REST APIs"] },
  { category: "Bases de Datos", items: ["PostgreSQL", "SQLite", "Firebase", "Firestore"] },
  { category: "Herramientas", items: ["Git", "GitHub", "VS Code", "Figma", "Docker"] },
];

const whyChooseMe = [
  {
    title: "Entiendo tu negocio",
    description: "No solo escribo código. Entiendo que necesitás soluciones que generen resultados reales para tu empresa.",
    icon: "business"
  },
  {
    title: "Comunicación clara",
    description: "Sin tecnicismos confusos. Te explico todo en lenguaje que puedas entender y tomar decisiones.",
    icon: "communication"
  },
  {
    title: "Compromiso real",
    description: "Cada proyecto lo tomo como propio. No me conformo hasta que estás 100% satisfecho con el resultado.",
    icon: "commitment"
  },
  {
    title: "Precios justos",
    description: "Sin sorpresas. Cotizaciones claras y transparentes desde el inicio, sin costos ocultos.",
    icon: "price"
  }
];
---

<Layout title="Sobre Mí" description="Conoce más sobre Daniel Ceballos, desarrollador Full Stack especializado en soluciones web para negocios chilenos.">
  <section class="py-20">
    <div class="container mx-auto px-6 max-w-4xl">
      
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-4">
          Sobre Mí
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Conoce quién está detrás de DC Dev y por qué puede confiar en mí para tu proyecto.
        </p>
      </div>

      <!-- Historia -->
      <div class="bg-slate-800/30 border border-slate-700/50 rounded-2xl p-8 mb-12">
        <h2 class="text-2xl font-bold text-slate-100 mb-6">Mi Historia</h2>
        <div class="space-y-4 text-slate-400 leading-relaxed">
          <p>
            Soy <strong class="text-slate-200">Daniel Ceballos</strong>, estudiante de Analista Programador con pasión por crear soluciones web que realmente funcionan para los negocios.
          </p>
          <p>
            Empecé en el mundo de la programación porque me fascinaba la idea de que una buena herramienta digital puede transformar la forma en que un negocio opera y genera ingresos.
          </p>
          <p>
            A lo largo de mi trayectoria, he trabajado con pequeños y medianos emprendedores chilenos que necesitaban digitalizarse pero no tenían el presupuesto de una empresa grande. Esa experiencia me enseñó a crear soluciones prácticas, funcionales y accesibles.
          </p>
          <p>
            Hoy, con <strong class="text-emerald-400">DC Dev</strong>, me dedico a desarrollar sistemas de agendamiento y catálogos web que ayudan a negocios como el tuyo a captar más clientes, organizar su operación y crecer sin complicaciones tecnológicas.
          </p>
        </div>
      </div>

      <!-- Habilidades Técnicas -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-100 mb-8 text-center">Habilidades Técnicas</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {skills.map((skillGroup) => (
            <div class="bg-slate-800/30 border border-slate-700/50 rounded-xl p-6">
              <h3 class="text-lg font-semibold text-emerald-400 mb-4">{skillGroup.category}</h3>
              <div class="flex flex-wrap gap-2">
                {skillGroup.items.map((skill) => (
                  <span class="px-3 py-1.5 bg-slate-800/50 border border-slate-700/50 text-slate-300 text-sm rounded-lg">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Por qué elegirme -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-100 mb-8 text-center">¿Por qué trabajar conmigo?</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {whyChooseMe.map((reason) => (
            <div class="bg-slate-800/30 border border-slate-700/50 rounded-xl p-6 hover:border-emerald-500/30 transition-colors">
              <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4">
                {reason.icon === "business" && (
                  <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                )}
                {reason.icon === "communication" && (
                  <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                )}
                {reason.icon === "commitment" && (
                  <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
                {reason.icon === "price" && (
                  <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
              </div>
              <h3 class="text-lg font-semibold text-slate-100 mb-2">{reason.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{reason.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center p-8 bg-slate-800/30 border border-slate-700/50 rounded-2xl">
        <h3 class="text-xl font-bold text-slate-100 mb-2">¿Hablamos?</h3>
        <p class="text-slate-400 mb-6">Estoy listo para ayudarte con tu próximo proyecto.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/Portafolio/contacto"
            class="px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/25"
          >
            Pedir Cotización
          </a>
          <a 
            href="/Portafolio/projects"
            class="px-6 py-3 border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-slate-100 font-medium rounded-lg transition-all duration-300"
          >
            Ver mis Proyectos
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>