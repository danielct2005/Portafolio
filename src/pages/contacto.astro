---
import Layout from '../layouts/Layout.astro';

const service = Astro.url.searchParams.get('service') || '';

// IMPORTANT: Reemplaza 'TU_FORM_ID' con tu ID de Formspree
// Crea tu formulario gratis en https://formspree.io/
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xojpkdlv';
---

<Layout title="Contacto" description="Escríbeme para pedir una cotización">
  <section class="py-20">
    <div class="container mx-auto px-6 max-w-2xl">
      <!-- Título -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-4">
          Hablemos
        </h1>
        <p class="text-slate-400 text-lg">
          Cuéntame sobre tu proyecto y te envío una cotización.
        </p>
      </div>

      <!-- Formulario -->
      <form 
        id="contact-form"
        action={FORMSPREE_ENDPOINT}
        method="POST"
        class="bg-slate-800/50 border border-slate-700/50 rounded-2xl p-8 space-y-6"
      >
        <!-- Honeypot anti-spam (campo oculto) -->
        <input type="text" name="website" id="website" class="hidden" tabindex="-1" autocomplete="off" style="position: absolute; left: -9999px;" />
        
        <!-- Nombre -->
        <div>
          <label for="name" class="block text-slate-300 font-medium mb-2">
            Tu Nombre
          </label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            required
            class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700 rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors"
            placeholder="Juan Pérez"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-slate-300 font-medium mb-2">
            Tu Email
          </label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required
            class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700 rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors"
            placeholder="juan@tuempresa.cl"
          />
        </div>

        <!-- Servicio -->
        <div>
          <label for="service" class="block text-slate-300 font-medium mb-2">
            ¿Qué necesitas?
          </label>
          <select 
            id="service" 
            name="service"
            class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700 rounded-lg text-slate-100 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors"
          >
            <option value="">Selecciona una opción</option>
            <option value="Sistema de Agendamiento" selected={service === 'agendamiento'}>Sistema de Agendamiento</option>
            <option value="Catálogo Digital" selected={service === 'catalogo'}>Catálogo Digital</option>
            <option value="Sitio Web Corporativo" selected={service === 'web'}>Sitio Web Corporativo</option>
            <option value="Otro Proyecto">Otro Proyecto</option>
          </select>
        </div>

        <!-- Mensaje -->
        <div>
          <label for="message" class="block text-slate-300 font-medium mb-2">
            Cuéntame más sobre tu proyecto
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows="5"
            required
            class="w-full px-4 py-3 bg-slate-900/50 border border-slate-700 rounded-lg text-slate-100 placeholder-slate-500 focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors resize-none"
            placeholder="¿En qué consiste tu proyecto? ¿Qué necesitas resolver?"
          ></textarea>
        </div>

        <!-- Botón enviar -->
        <button 
          type="submit"
          id="submit-btn"
          class="w-full py-4 bg-emerald-500 hover:bg-emerald-400 text-slate-900 font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-emerald-500/25 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Enviar Mensaje
        </button>

        <p class="text-slate-500 text-sm text-center">
          También puedes escribirme directamente a <a href="mailto:daniel.dcdev04@gmail.com" class="text-emerald-400 hover:underline">daniel.dcdev04@gmail.com</a>
        </p>
      </form>

      <!-- Mensaje de éxito (oculto por defecto) -->
      <div id="success-message" class="hidden mt-6 p-6 bg-emerald-500/10 border border-emerald-500/30 rounded-2xl text-center">
        <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-emerald-500/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-slate-100 mb-2">¡Gracias por contactarme!</h3>
        <p class="text-slate-400">Te respondere pronto. Mientras tanto, puedes seguir viendo mi trabajo en la sección de proyectos.</p>
        <a href="/Portafolio/projects" class="inline-block mt-4 text-emerald-400 hover:text-emerald-300 font-medium">
          Ver Proyectos →
        </a>
      </div>

      <!-- Mensaje de error (oculto por defecto) -->
      <div id="error-message" class="hidden mt-6 p-6 bg-red-500/10 border border-red-500/30 rounded-2xl text-center">
        <h3 class="text-xl font-bold text-red-400 mb-2">Algo salió mal</h3>
        <p class="text-slate-400">Por favor intenta de nuevo o escríbeme directamente a mi email.</p>
      </div>

      <!-- Volver -->
      <div class="text-center mt-8" id="back-link">
        <a 
          href="/Portafolio/" 
          class="inline-flex items-center gap-2 text-slate-400 hover:text-emerald-400 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMessage = document.getElementById('success-message');
  const errorMessage = document.getElementById('error-message');
  const backLink = document.getElementById('back-link');
  const honeypot = document.getElementById('website') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    // Verificar honeypot - si está lleno, es un bot
    if (honeypot && honeypot.value) {
      e.preventDefault();
      // Simular envío exitoso para engañar al bot
      form.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      if (backLink) backLink.classList.add('hidden');
      return;
    }

    e.preventDefault();

    // Desactivar botón mientras envía
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';

    try {
      const formData = new FormData(form);
      
      const response = await fetch(form.action, {
        method: 'POST',
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        // Mostrar mensaje de éxito
        form.classList.add('hidden');
        successMessage?.classList.remove('hidden');
        if (backLink) backLink.classList.add('hidden');
      } else {
        throw new Error('Error en el envío');
      }
    } catch (error) {
      // Mostrar mensaje de error
      form.classList.add('hidden');
      errorMessage?.classList.remove('hidden');
      if (backLink) backLink.classList.add('hidden');
    }
  });
</script>