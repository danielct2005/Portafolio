---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Layout title="Inicio">
  <Hero />

  <!-- Servicios -->
  <Services />

  <!-- Proyectos Destacados -->
    <div class="container mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-100 mb-4">
          Proyectos
        </h2>
        <p class="text-slate-400 max-w-2xl mx-auto">
          Trabajos reales que demuestran lo que puedo hacer por tu negocio.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredProjects.map((project, index) => (
          <ProjectCard project={project} index={index} />
        ))}
      </div>

      {featuredProjects.length === 0 && (
        <div class="text-center py-12">
          <p class="text-slate-400 mb-4">No hay proyectos todavía.</p>
          <a href="/projects" class="text-emerald-400 hover:text-emerald-300">
            Ver página de proyectos &rarr;
          </a>
        </div>
      )}

      <div class="text-center mt-12">
        <a 
          href="/projects" 
          class="inline-flex items-center gap-2 px-6 py-3 text-emerald-400 hover:text-emerald-300 font-medium transition-colors"
        >
          Ver todos los proyectos
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-800/30">
    <div class="container mx-auto px-6 max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-slate-100 mb-6">Sobre Mí</h2>
      <p class="text-lg text-slate-400 leading-relaxed">
        Soy estudiante de Analista Programador con pasión por crear experiencias web modernas y eficientes. 
        Me especializo en desarrollo frontend con enfoque en rendimiento, accesibilidad y buenas prácticas de código.
      </p>
    </div>
  </section>
</Layout>